  "recettes": {
    "bowl": {
      "nom": "Bowl lentilles & sardines méditerranéen",
      "temps": "30 min",
      "portions": 4,
      "budget": "~5€",
      "macros": {
        "kcal": 520,
        "proteines": 38,
        "glucides": 55,
        "lipides": 14
      },
      "ingredients": [
        "400g lentilles vertes sèches",
        "3 boîtes de sardines à l'huile d'olive (375g net égoutté)",
        "2 tomates moyennes, coupées en dés",
        "1 concombre, coupé en dés",
        "1 oignon rouge, émincé fin",
        "1 bouquet de persil frais, haché",
        "2 c.à.s. huile d'olive",
        "Jus de 1 citron",
        "1 c.à.c. cumin moulu",
        "Sel, poivre"
      ],
      "preparation": [
        "Cuire les lentilles dans 3× leur volume d'eau salée, ~20 min. Égoutter et laisser tiédir.",
        "Préparer la vinaigrette : huile d'olive + jus de citron + cumin + sel + poivre.",
        "Mélanger les lentilles avec les tomates, concombre, oignon rouge, persil.",
        "Émietter les sardines égouttées par-dessus.",
        "Arroser de vinaigrette et mélanger délicatement."
      ],
      "notes": [
        "Se conserve 3 jours au frigo. Sortir 15 min avant de servir.",
        "Jad : servir ~350g de lentilles + sardines complètes. Accompagnant·e : ~200g de lentilles + moitié des sardines."
      ]
    },
    "curry": {
      "nom": "Curry de pois chiches & cabillaud au lait de coco",
      "temps": "35 min",
      "portions": 4,
      "budget": "~7€",
      "macros": {
        "kcal": 560,
        "proteines": 35,
        "glucides": 52,
        "lipides": 20
      },
      "ingredients": [
        "400g filets de cabillaud surgelés",
        "2 boîtes de pois chiches (480g égouttés)",
        "1 boîte de lait de coco (400ml)",
        "200g épinards frais (ou surgelés)",
        "1 oignon, émincé",
        "3 gousses d'ail, hachées",
        "1 morceau de gingembre frais (3cm), râpé",
        "2 c.à.s. pâte de curry (jaune ou rouge)",
        "200g riz basmati (pour servir)",
        "1 c.à.s. huile de colza",
        "Jus de 1/2 citron vert",
        "Coriandre fraîche (optionnel)"
      ],
      "preparation": [
        "Lancer le riz selon les instructions du paquet.",
        "Faire revenir l'oignon dans l'huile 3 min. Ajouter ail, gingembre et pâte de curry, cuire 1 min.",
        "Ajouter le lait de coco et les pois chiches égouttés. Porter à frémissement.",
        "Couper le cabillaud en morceaux de 3cm, l'ajouter au curry. Cuire 8-10 min à feu moyen.",
        "Ajouter les épinards, cuire 2 min jusqu'à ce qu'ils fondent.",
        "Jus de citron vert, sel, poivre. Servir sur le riz."
      ],
      "notes": [
        "Se réchauffe très bien. Conserver riz et curry séparément.",
        "Jad : portion généreuse de riz (~180g cru) + curry complet. Accompagnant·e : ~100g riz + curry."
      ]
    },
    "padthai": {
      "nom": "Pad thaï au tofu & œufs",
      "temps": "25 min",
      "portions": 4,
      "budget": "~6€",
      "macros": {
        "kcal": 510,
        "proteines": 30,
        "glucides": 58,
        "lipides": 16
      },
      "ingredients": [
        "300g nouilles de riz (pad thaï)",
        "400g tofu ferme, coupé en cubes",
        "4 œufs",
        "2 carottes, râpées",
        "200g pousses de soja (ou germes de haricot mungo)",
        "4 oignons verts, émincés",
        "60g cacahuètes concassées",
        "2 citrons verts",
        "Sauce : 3 c.à.s. sauce soja, 2 c.à.s. beurre de cacahuète, 1 c.à.s. sirop d'érable (ou sucre), 1 c.à.s. huile de sésame, 1 c.à.s. vinaigre de riz, sriracha au goût"
      ],
      "preparation": [
        "Tremper les nouilles de riz dans l'eau chaude 8 min (ou selon paquet). Égoutter.",
        "Mélanger tous les ingrédients de la sauce dans un bol.",
        "Faire dorer le tofu à feu vif dans une grande poêle/wok huilé, 5 min. Réserver.",
        "Dans la même poêle, brouiller les 4 œufs. Réserver avec le tofu.",
        "Sauter les carottes et pousses de soja 2 min.",
        "Ajouter les nouilles, la sauce, le tofu et les œufs. Mélanger 2 min à feu vif.",
        "Servir avec cacahuètes, oignons verts et quartiers de citron vert."
      ],
      "notes": [
        "Cuisiner 2 fois dans la semaine (lun-mar + ven) pour garder la fraîcheur des nouilles.",
        "Jad : portion XL (~400g). Accompagnant·e : portion normale (~250g)."
      ]
    },
    "gratin": {
      "nom": "Gratin de pâtes aux œufs & épinards",
      "temps": "40 min",
      "portions": 4,
      "budget": "~5€",
      "macros": {
        "kcal": 540,
        "proteines": 32,
        "glucides": 60,
        "lipides": 16
      },
      "ingredients": [
        "400g pâtes (penne ou fusilli)",
        "6 œufs",
        "300g épinards frais (ou 200g surgelés)",
        "1 boîte de thon au naturel (200g égouttés)",
        "200ml lait d'avoine",
        "2 c.à.s. levure nutritionnelle (pour le goût \"fromager\")",
        "1 c.à.s. moutarde de Dijon",
        "2 gousses d'ail, hachées",
        "40g chapelure",
        "2 c.à.s. huile d'olive",
        "Noix de muscade, sel, poivre"
      ],
      "preparation": [
        "Préchauffer le four à 200°C. Cuire les pâtes al dente, égoutter.",
        "Faire revenir l'ail dans l'huile d'olive 1 min. Ajouter les épinards, cuire jusqu'à ce qu'ils fondent (3 min).",
        "Battre les œufs avec le lait d'avoine, la levure nutritionnelle, la moutarde, sel, poivre, muscade.",
        "Mélanger pâtes + épinards + thon émietté dans un plat à gratin.",
        "Verser le mélange œufs par-dessus. Saupoudrer de chapelure.",
        "Enfourner 20 min jusqu'à ce que le dessus soit doré."
      ],
      "notes": [
        "Se conserve 3 jours au frigo, se réchauffe au four 10 min à 180°C.",
        "La levure nutritionnelle remplace le fromage râpé : goût umami sans produit laitier.",
        "Jad : 1/3 du plat. Accompagnant·e : 1/4 du plat."
      ]
    }

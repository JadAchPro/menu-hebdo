  "recettes": {
    "saumon": {
      "nom": "Saumon teriyaki, edamames & riz",
      "temps": "30 min",
      "portions": 4,
      "budget": "~8 €",
      "macros": {
        "kcal": 540,
        "proteines": 36,
        "glucides": 52,
        "lipides": 18
      },
      "ingredients": [
        "500g paves de saumon (frais ou surgeles)",
        "200g edamames decortiques (surgeles)",
        "250g riz basmati",
        "2 carottes, taillees en julienne",
        "200g brocoli, en petits bouquets",
        "2 oignons verts, eminces",
        "1 c.a.s. graines de sesame",
        "<strong>Sauce teriyaki :</strong> 4 c.a.s. sauce soja, 2 c.a.s. sirop d'erable, 1 c.a.s. vinaigre de riz, 1 c.a.c. maizena, 1 gousse d'ail rapee, 1 cm gingembre rape"
      ],
      "preparation": [
        "Cuire le riz selon les instructions. En parallele, cuire les edamames et le brocoli a la vapeur ou dans l'eau bouillante 5 min.",
        "Melanger les ingredients de la sauce teriyaki dans un bol.",
        "Couper le saumon en morceaux de 3 cm. Saisir dans une poele chaude huilee 3 min de chaque cote.",
        "Verser la sauce teriyaki sur le saumon, laisser epaissir 2 min a feu moyen.",
        "Dresser : riz, edamames, brocoli, carottes crues en julienne, saumon nappe de sauce.",
        "Parsemer d'oignons verts et graines de sesame."
      ],
      "notes": [
        "Conserver riz et garnitures separement du saumon. Se conserve 3 jours au frigo.",
        "Jad : 180g riz cru + saumon genereux (~200g). Accompagnant·e : 100g riz + ~130g saumon."
      ]
    },
    "shakshuka": {
      "nom": "Shakshuka aux haricots blancs",
      "temps": "25 min",
      "portions": 4,
      "budget": "~5 €",
      "macros": {
        "kcal": 520,
        "proteines": 32,
        "glucides": 48,
        "lipides": 18
      },
      "ingredients": [
        "8 oeufs",
        "2 boites de haricots blancs (480g egouttes)",
        "2 boites de tomates concassees (800g)",
        "2 poivrons rouges, coupes en des",
        "1 oignon, emince",
        "3 gousses d'ail, hachees",
        "2 c.a.c. cumin moulu",
        "2 c.a.c. paprika fume",
        "1 c.a.c. piment d'Espelette (ou chili)",
        "2 c.a.s. huile d'olive",
        "Persil frais, hache",
        "4-6 tranches de pain complet (pour servir)"
      ],
      "preparation": [
        "Faire revenir l'oignon et les poivrons dans l'huile d'olive 5 min. Ajouter l'ail et les epices, cuire 1 min.",
        "Ajouter les tomates concassees et les haricots blancs egouttes. Saler, poivrer. Laisser mijoter 10 min.",
        "Creer 8 puits dans la sauce, casser un oeuf dans chaque puits.",
        "Couvrir et cuire 5-7 min a feu doux jusqu'a ce que les blancs soient pris (jaunes encore coulants).",
        "Parsemer de persil. Servir avec du pain complet grille."
      ],
      "notes": [
        "La sauce se conserve 3 jours. Pour recuisiner : rechauffer la sauce et casser de nouveaux oeufs dedans.",
        "Jad : 3 oeufs + sauce genereuse + 2 tranches de pain. Accompagnant·e : 2 oeufs + sauce + 1 tranche."
      ]
    },
    "tacos": {
      "nom": "Tacos de tempeh & haricots noirs",
      "temps": "30 min",
      "portions": 4,
      "budget": "~7 €",
      "macros": {
        "kcal": 530,
        "proteines": 34,
        "glucides": 50,
        "lipides": 18
      },
      "ingredients": [
        "400g tempeh, emiette",
        "1 boite de haricots noirs (240g egouttes)",
        "8-12 tortillas de ble ou mais",
        "2 avocats murs",
        "200g tomates cerises, coupees en deux",
        "1/2 chou rouge, emince fin",
        "1 oignon, emince",
        "Jus de 2 citrons verts",
        "Coriandre fraiche",
        "<strong>Epices :</strong> 2 c.a.c. cumin, 1 c.a.c. paprika fume, 1 c.a.c. poudre de chili, 1/2 c.a.c. origan",
        "2 c.a.s. sauce soja",
        "1 c.a.s. huile de colza"
      ],
      "preparation": [
        "Emietter le tempeh. Le faire revenir dans l'huile avec l'oignon 5 min.",
        "Ajouter les epices et la sauce soja, cuire 2 min. Ajouter les haricots noirs egouttes, cuire 3 min.",
        "Preparer le guacamole : ecraser les avocats + jus de citron vert + sel.",
        "Emincer le chou rouge, l'assaisonner avec un filet de citron vert.",
        "Rechauffer les tortillas 30 sec a la poele seche.",
        "Assembler : tortilla + garniture tempeh-haricots + guacamole + chou rouge + tomates + coriandre."
      ],
      "notes": [
        "La garniture tempeh-haricots se conserve 3 jours. Preparer le guacamole frais au moment de servir.",
        "Jad : 3-4 tacos genereux. Accompagnant·e : 2-3 tacos."
      ]
    },
    "risotto": {
      "nom": "Risotto crevettes & asperges au lait de coco",
      "temps": "35 min",
      "portions": 4,
      "budget": "~8 €",
      "macros": {
        "kcal": 550,
        "proteines": 32,
        "glucides": 58,
        "lipides": 16
      },
      "ingredients": [
        "400g crevettes decortiquees (fraiches ou surgelees)",
        "300g riz arborio (ou riz rond)",
        "1 botte d'asperges vertes (~300g), coupees en troncons de 3 cm",
        "200ml lait de coco",
        "800ml bouillon de legumes chaud",
        "1 oignon, emince fin",
        "2 gousses d'ail, hachees",
        "100ml vin blanc sec (ou jus de citron + bouillon)",
        "2 c.a.s. levure nutritionnelle",
        "2 c.a.s. huile d'olive",
        "Zeste de 1 citron",
        "Sel, poivre"
      ],
      "preparation": [
        "Faire revenir l'oignon dans l'huile d'olive 3 min. Ajouter l'ail, cuire 1 min.",
        "Ajouter le riz arborio, nacrer 2 min en remuant.",
        "Deglacer au vin blanc. Ajouter le bouillon louche par louche en remuant regulierement (~18 min).",
        "A mi-cuisson, ajouter les asperges.",
        "En parallele, saisir les crevettes dans une poele chaude 2 min de chaque cote. Saler, poivrer.",
        "En fin de cuisson du riz, incorporer le lait de coco et la levure nutritionnelle. Remuer.",
        "Dresser le risotto, disposer les crevettes par-dessus, zeste de citron."
      ],
      "notes": [
        "Le risotto se conserve 3 jours. Rechauffer a la poele avec un peu de bouillon pour redonner de l'onctuosite.",
        "La levure nutritionnelle apporte un gout umami/fromager sans produit laitier.",
        "Jad : portion XL (~400g risotto + crevettes genereuses). Accompagnant·e : ~280g."
      ]
    }
  },
